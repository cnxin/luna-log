{
    "expo":  {
                 "name":  "Luna Log",
                 "slug":  "luna-log",
                 "version":  "1.0.7",
                 "orientation":  "portrait",
                 "icon":  "./assets/app-icons/icon-1024.png",
                 "userInterfaceStyle":  "light",
                 "ios":  {
                             "supportsTablet":  true
                         },
                 "android":  {
                                 "adaptiveIcon":  {
                                                      "foregroundImage":  "./assets/app-icons/adaptive-icon-foreground.png",
                                                      "backgroundColor":  "#F8FBFF"
                                                  },
                                 "predictiveBackGestureEnabled":  false,
                                 "package":  "com.anonymous.lunalog",
                                 "versionCode":  8,
                                 "permissions":  [
                                                     "INTERNET",
                                                     "REQUEST_INSTALL_PACKAGES"
                                                 ]
                             },
                 "web":  {
                             "favicon":  "./assets/app-icons/favicon-512.png"
                         },
                 "plugins":  [
                                 "expo-sharing"
                             ]
             }
}
